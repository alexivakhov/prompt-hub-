{
  "manifest_version": 3,
  "name": "Aineurit Prompt Hub",
  "version": "1.3.0",
  "description": "Save, organize and copy AI prompts with template variables.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Aineurit Prompt Hub"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
